# CONFIGURACIÓN — RED NEURONAL ENFERMEDADES FOLIARES TOMATE

# ── Rutas (absolutas o relativas al directorio de ejecución)
DATA_DIR=
RESULTS_DIR=resultados
MODELS_DIR=modelos
EXPORT_DIR=exportado

# ── Clases (separadas por coma, sin espacios)
CLASES=moho_foliar,sanas,tizon_temprano,TYLCV

# ── Imagen y batch
IMG_SIZE=224
BATCH_SIZE=100

# ── Grilla de hiperparámetros
CAPAS_OPCIONES=64|32|64-32|128-64|128-64-32

DROPOUT_OPCIONES=0.3,0.5
LR_OPCIONES=0.0001,0.001,0.01,1
EPOCAS_OPCIONES=25
ACTIVACION_OPCIONES=ReLU,GELU

# ── Semilla base (se multiplica por índice de experimento)
SEED_BASE=42

# ── INDEX de la GPU (0 para primera GPU; dejar vacío para CPU)
CUDA_DEVICE_INDEX=0

# ── Normalización ImageNet (media y desv. estándar por canal RGB)
IMG_NORMALIZE_MEAN=0.485,0.456,0.406
IMG_NORMALIZE_STD=0.229,0.224,0.225

# ── Scheduler de tasa de aprendizaje
LR_SCHEDULER_PATIENCE=5
LR_SCHEDULER_FACTOR=0.5

# ── Exportación ONNX
ONNX_OPSET_VERSION=11
