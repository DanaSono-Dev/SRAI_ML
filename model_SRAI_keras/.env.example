# Rutas base (ajusta a tu sistema)
BASE_DIR=/ruta/absoluta/al/proyecto
NPZ_DIR=${BASE_DIR}/NPZ
NPZ_FILE=${NPZ_DIR}/DB.npz

# Modelo (fecha del directorio que contiene model_best.keras)
MODEL_DATE=2026-06-22
MODEL_PATH=${BASE_DIR}/${MODEL_DATE}/model_best.keras

# Dataset
IMAGE_SIZE=256
NUM_CLASSES=4
BATCH_SIZE=32
NUM_EPOCHS=2000

# Scheduler
EPOCH_FDECAY=50

# Split train/test/val (deben sumar 1.0)
SPLIT_TRAIN=0.70
SPLIT_TEST=0.15
SPLIT_VAL=0.15

# GPU
TF_CPP_MIN_LOG_LEVEL=3
TF_ENABLE_ONEDNN_OPTS=0

# Semilla de aleatoriedad
RANDOM_SEED=0

# Entrenamiento - Control
PLOT_SAVE_INTERVAL=25
EARLY_STOP_THRESHOLD=0.002
EARLY_STOP_WINDOW=20
THREAD_POOL_WORKERS=2

# Evaluacion (MC.py)
PRED_BATCH_SIZE=16
CLASS_LABELS=Clase0,Clase1,Clase2,Clase3
CM_OUTPUT_NAME=MC_Aumen
CM_OUTPUT_DPI=600
CM_FIGURE_DPI=300
CM_CMAP=Purples

# Optimizador
INITIAL_LR=0.0002
COSINE_T_MUL=1.5
COSINE_M_MUL=1.5
COSINE_ALPHA=1e-9
ADAM_BETA1=0.5
ADAM_BETA2=0.8

# Arquitectura
DROPOUT_RATE=0.3
